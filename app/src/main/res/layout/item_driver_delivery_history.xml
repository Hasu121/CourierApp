<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@color/courier_card"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status"
        android:textColor="@color/courier_dark"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvCustomer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Customer"
        android:textColor="@color/courier_dark" />

    <TextView
        android:id="@+id/tvPickup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Pickup"
        android:textColor="@color/courier_dark" />

    <TextView
        android:id="@+id/tvDrop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Drop"
        android:textColor="@color/courier_dark" />

    <TextView
        android:id="@+id/tvFareDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Fare / Distance"
        android:textColor="@color/courier_dark" />

    <TextView
        android:id="@+id/tvDeliveredAt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Delivered At"
        android:textColor="@color/courier_dark" />

    <EditText
        android:id="@+id/etDriverRating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:hint="Rating customer 1-5"
        android:inputType="number"
        android:textColor="@color/courier_dark"
        android:textColorHint="@color/courier_gray_text" />

    <EditText
        android:id="@+id/etDriverReviewComment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Comment for customer"
        android:textColor="@color/courier_dark"
        android:textColorHint="@color/courier_gray_text" />

    <Button
        android:id="@+id/btnSubmitDriverReview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/courier_green"
        android:text="Submit Customer Review"
        android:textColor="@color/courier_white" />

</LinearLayout>