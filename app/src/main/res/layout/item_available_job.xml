<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@color/courier_card"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvJobType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Type"
        android:textColor="@color/courier_dark"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvPickup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Pickup"
        android:textColor="@color/courier_dark" />

    <TextView
        android:id="@+id/tvDrop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Drop"
        android:textColor="@color/courier_dark" />

    <TextView
        android:id="@+id/tvPackage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Package"
        android:textColor="@color/courier_dark" />

    <TextView
        android:id="@+id/tvReceiver"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Receiver"
        android:textColor="@color/courier_dark" />

    <TextView
        android:id="@+id/tvFareDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Fare / Distance"
        android:textColor="@color/courier_dark" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Status"
        android:textColor="@color/courier_dark" />

    <Button
        android:id="@+id/btnAcceptJob"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/courier_green"
        android:text="Accept Job"
        android:textColor="@color/courier_white" />

</LinearLayout>