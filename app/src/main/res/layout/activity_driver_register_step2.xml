<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/courier_light_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:background="@color/courier_card"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Driver Register - Step 2"
            android:textColor="@color/courier_dark"
            android:textSize="28sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etVehicleType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Vehicle Type (bike/car/truck)"
            android:textColor="@color/courier_dark"
            android:textColorHint="@color/courier_gray_text" />

        <EditText
            android:id="@+id/etVehicleNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Vehicle Number"
            android:textColor="@color/courier_dark"
            android:textColorHint="@color/courier_gray_text" />

        <EditText
            android:id="@+id/etLicenseNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="License Number"
            android:textColor="@color/courier_dark"
            android:textColorHint="@color/courier_gray_text" />

        <EditText
            android:id="@+id/etNidNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="NID Number"
            android:textColor="@color/courier_dark"
            android:textColorHint="@color/courier_gray_text" />

        <EditText
            android:id="@+id/etServiceMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Service Mode (within_city/intercity/both)"
            android:textColor="@color/courier_dark"
            android:textColorHint="@color/courier_gray_text" />

        <Button
            android:id="@+id/btnRegisterDriver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/courier_green"
            android:text="Register Driver"
            android:textColor="@color/courier_white" />

    </LinearLayout>
</ScrollView>