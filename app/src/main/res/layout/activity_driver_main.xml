<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/driverDrawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/courier_light_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/courier_light_bg"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/driverTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/courier_green"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/driverTopBarInner"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:id="@+id/btnDriverMenu"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:text="☰"
                    android:textColor="@color/courier_white"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDriverTopTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Driver Home"
                    android:textColor="@color/courier_white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDriverTopRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/courier_white"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="Driver"
                    android:textColor="@color/courier_green"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/driverFragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/courier_light_bg" />

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigationDriver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/courier_white"
            app:itemIconTint="@color/courier_dark"
            app:itemTextColor="@color/courier_dark"
            app:menu="@menu/driver_bottom_menu" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/driverDrawerContent"
        android:layout_width="290dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/courier_white"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvDrawerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Driver Name"
            android:textColor="@color/courier_dark"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDrawerEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="email@example.com"
            android:textColor="@color/courier_dark" />

        <TextView
            android:id="@+id/tvDrawerRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Driver"
            android:textColor="@color/courier_dark" />

        <TextView
            android:id="@+id/tvDrawerVehicle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Vehicle: -"
            android:textColor="@color/courier_dark" />

        <Button
            android:id="@+id/btnDrawerCheckProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:backgroundTint="@color/courier_green"
            android:text="Profile"
            android:textColor="@color/courier_white" />

        <Button
            android:id="@+id/btnDrawerGoEarnings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/courier_green"
            android:text="Earnings"
            android:textColor="@color/courier_white" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnDrawerLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/courier_error"
            android:text="Logout"
            android:textColor="@color/courier_white" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>