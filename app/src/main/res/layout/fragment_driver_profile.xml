<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/courier_light_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Driver Profile"
            android:textColor="@color/courier_dark"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@color/courier_card"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/etFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Full Name"
                android:textColor="@color/courier_dark"
                android:textColorHint="@color/courier_gray_text" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:enabled="false"
                android:hint="Email"
                android:textColor="@color/courier_dark"
                android:textColorHint="@color/courier_gray_text" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Phone"
                android:inputType="phone"
                android:textColor="@color/courier_dark"
                android:textColorHint="@color/courier_gray_text" />

            <EditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Address"
                android:textColor="@color/courier_dark"
                android:textColorHint="@color/courier_gray_text" />

            <EditText
                android:id="@+id/etVehicleType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Vehicle Type"
                android:textColor="@color/courier_dark"
                android:textColorHint="@color/courier_gray_text" />

            <EditText
                android:id="@+id/etVehicleNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Vehicle Number"
                android:textColor="@color/courier_dark"
                android:textColorHint="@color/courier_gray_text" />

            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Rating: 0.0"
                android:textColor="@color/courier_dark"
                android:textStyle="bold" />

        </LinearLayout>

        <Button
            android:id="@+id/btnChangeInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/courier_green"
            android:text="Change Information"
            android:textColor="@color/courier_white" />

        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/courier_gray_text"
            android:text="Save Changes"
            android:textColor="@color/courier_white" />

    </LinearLayout>
</ScrollView>