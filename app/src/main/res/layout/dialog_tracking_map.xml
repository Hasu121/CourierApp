<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.maplibre.android.maps.MapView
        android:id="@+id/mapViewFullTracking"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/trackingTopControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTrackingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#DDFFFFFF"
            android:padding="10dp"
            android:text="Tracking Map"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCloseTrackingMap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Close" />

        <Button
            android:id="@+id/btnCenterPickupFull"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Center Pickup" />

        <Button
            android:id="@+id/btnCenterDropFull"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Center Drop" />

        <Button
            android:id="@+id/btnCenterDriverFull"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Center Driver" />
    </LinearLayout>

</FrameLayout>