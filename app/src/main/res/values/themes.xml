<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.CourierApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/courier_green</item>
        <item name="colorPrimaryVariant">@color/courier_green</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <item name="android:statusBarColor">@color/courier_green</item>
        <item name="android:navigationBarColor">@color/courier_light_bg</item>

        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">true</item>

        <item name="android:fontFamily">sans</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>

</resources>